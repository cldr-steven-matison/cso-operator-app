# Mac dev overrides — assumes scripts/mac-dev.sh port-forwards.
# Copy to .env.local to activate.

VLLM_URL=http://localhost:8000
QDRANT_URL=http://localhost:6333
EMBED_URL=http://localhost:8080
WHISPER_URL=http://localhost:8001

# NiFi via the cluster ingress (with /etc/hosts mapping the FQDN to 127.0.0.1).
NIFI_URL=https://mynifi-web.mynifi.cfm-streaming.svc.cluster.local
NIFI_VERIFY_TLS=false
# kubectl get secret nifi-admin-creds -n cfm-streaming -o jsonpath='{.data.username}' | base64 -d
NIFI_USERNAME=admin
# kubectl get secret nifi-admin-creds -n cfm-streaming -o jsonpath='{.data.password}' | base64 -d
NIFI_PASSWORD=

# Kafka: external listener via per-broker port-forwards from
# scripts/mac-dev.sh. Required because the internal listener advertises
# in-cluster broker hostnames the host can't resolve.
KAFKA_BOOTSTRAP=localhost:19090
